# ──────────────────────────────────────────────────────────────────────────────
# inRebus website — environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── "Send a Brief" form ───────────────────────────────────────────────────────
# Create a free Formspree form at https://formspree.io and paste the endpoint.
# Format: https://formspree.io/f/<your-form-id>
VITE_FORMSPREE_BRIEF_ENDPOINT=

# ── Newsletter subscription form ─────────────────────────────────────────────
# A separate Formspree form (or the same one with a hidden field).
VITE_FORMSPREE_NEWSLETTER_ENDPOINT=

# ── Optional: Resend (server-side only) ──────────────────────────────────────
# If you add a serverless function / edge route to proxy form submissions,
# set the Resend API key here. DO NOT expose this key in client-side code.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=noreply@inrebus.it
# RESEND_TO=info.educational@inrebus.it
